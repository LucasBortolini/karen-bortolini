---
interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<article class="card h-full">
  <h3 class="font-display text-lg font-semibold text-primary">{title}</h3>
  <p class="mt-2 text-sm leading-relaxed text-secondary">{description}</p>
</article>
