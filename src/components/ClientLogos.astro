---
import fs from 'node:fs';
import path from 'node:path';
import Section from './Section.astro';
import { sortClientLogos } from '../lib/client-logos';

const logosDir = path.join(process.cwd(), 'public/logos');
let logos = [];

try {
  if (fs.existsSync(logosDir)) {
    const files = fs
      .readdirSync(logosDir)
      .filter((f) => /\.(png|jpe?g|svg|webp)$/i.test(f));
    logos = sortClientLogos(files);
  }
} catch {
  logos = [];
}
---

{
  logos.length > 0 && (
    <Section title="Clientes e parceiros" subtitle="Quem confia no meu trabalho" variant="white">
      <ul class="grid grid-cols-2 items-center justify-items-center gap-x-6 gap-y-8 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5">
        {logos.map((logo) => (
          <li class="flex w-full items-center justify-center px-2">
            <img
              src={logo.src}
              alt={logo.alt}
              width="160"
              height="48"
              class="h-10 w-full max-w-[140px] object-contain opacity-75 grayscale transition duration-300 hover:opacity-100 hover:grayscale-0 sm:h-11 md:h-12"
              loading="lazy"
              decoding="async"
            />
          </li>
        ))}
      </ul>
    </Section>
  )
}
