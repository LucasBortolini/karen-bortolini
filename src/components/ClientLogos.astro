---
import fs from 'node:fs';
import path from 'node:path';

const logosDir = path.join(process.cwd(), 'public/logos');
let logoPaths: string[] = [];

try {
  if (fs.existsSync(logosDir)) {
    logoPaths = fs
      .readdirSync(logosDir)
      .filter((f) => /\.(png|jpe?g|svg|webp)$/i.test(f))
      .map((f) => `/logos/${f}`);
  }
} catch {
  logoPaths = [];
}
---

{
  logoPaths.length > 0 ? (
    <section class="bg-white py-12">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <p class="mb-8 text-center text-sm font-semibold uppercase tracking-wider text-secondary/70">
          Clientes e parceiros
        </p>
        <div class="flex flex-wrap items-center justify-center gap-8 md:gap-12">
          {logoPaths.map((src) => (
            <img
              src={src}
              alt=""
              class="h-10 max-w-[120px] object-contain opacity-70 grayscale transition hover:opacity-100 hover:grayscale-0 md:h-12"
              loading="lazy"
            />
          ))}
        </div>
      </div>
    </section>
  ) : (
    <section class="border-y border-primary/5 bg-white py-12">
      <div class="mx-auto max-w-6xl px-4 text-center sm:px-6 lg:px-8">
        <p class="text-sm text-secondary/60">
          Logos de clientes em breve — adicione arquivos em{' '}
          <code class="rounded bg-surface px-1 text-accent">public/logos/</code>
        </p>
      </div>
    </section>
  )
}
