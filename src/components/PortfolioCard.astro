---
import { portfolioTypeLabels, youtubeThumbnail } from '../lib/utils';

interface Props {
  title: string;
  url: string;
  type: string;
  group?: string;
}

const { title, url, type, group } = Astro.props;
const thumb = youtubeThumbnail(url);
const typeLabel = portfolioTypeLabels[type] ?? type;
---

<a
  href={url}
  target="_blank"
  rel="noopener noreferrer"
  class="card group block overflow-hidden p-0"
>
  <div class="relative aspect-video overflow-hidden bg-primary/10">
    {
      thumb ? (
        <img
          src={thumb}
          alt=""
          class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
          loading="lazy"
          width="480"
          height="270"
        />
      ) : (
        <div class="flex h-full items-center justify-center bg-primary/5">
          <span class="font-display text-2xl text-primary/40">{typeLabel}</span>
        </div>
      )
    }
    <span class="absolute left-3 top-3 rounded-full bg-accent px-2 py-0.5 text-xs font-semibold text-white">
      {typeLabel}
    </span>
  </div>
  <div class="p-4">
    {group && <p class="text-xs font-medium text-accent">{group}</p>}
    <h3 class="mt-1 font-display text-base font-semibold text-primary group-hover:text-accent">
      {title}
    </h3>
    <p class="mt-2 text-xs text-secondary/70">Abrir projeto →</p>
  </div>
</a>
