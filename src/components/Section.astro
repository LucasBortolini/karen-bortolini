---
interface Props {
  title?: string;
  subtitle?: string;
  variant?: 'light' | 'dark' | 'white';
  id?: string;
  class?: string;
}

const { title, subtitle, variant = 'light', id, class: className = '' } = Astro.props;

const variants = {
  light: 'bg-surface',
  dark: 'section-dark',
  white: 'bg-white',
};
---

<section id={id} class:list={['py-12 md:py-16', variants[variant], className]}>
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    {(title || subtitle) && (
      <header class="mb-10 md:mb-14">
        {subtitle && (
          <p
            class:list={[
              'mb-2 text-sm font-semibold uppercase tracking-wider',
              'text-gold',
            ]}
          >
            {subtitle}
          </p>
        )}
        {title && (
          <h2
            class:list={[
              'font-display text-3xl font-bold md:text-4xl',
              variant === 'dark' ? 'text-white' : 'text-primary',
            ]}
          >
            {title}
          </h2>
        )}
      </header>
    )}
    <slot />
  </div>
</section>
