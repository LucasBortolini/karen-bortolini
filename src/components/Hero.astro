---
import { getSiteSettings, whatsappUrl } from '../lib/site';

const settings = await getSiteSettings();
---

<section class="relative overflow-hidden bg-surface py-10 md:py-14">
  <div class="mx-auto grid max-w-6xl items-center gap-8 px-4 sm:px-6 lg:grid-cols-2 lg:gap-12 lg:px-8">
    <div class="fade-in order-2 lg:order-1">
      <p class="mb-3 text-sm font-semibold uppercase tracking-wider text-gold">
        {settings.heroSubtitle}
      </p>
      <h1 class="font-display text-3xl font-bold leading-tight text-primary sm:text-4xl md:text-5xl">
        {settings.heroTitle}
      </h1>
      <p class="mt-4 text-base leading-relaxed text-secondary md:text-lg">
        {settings.heroSummary}
      </p>
      <div class="mt-6 flex flex-col gap-3 sm:flex-row">
        <a href="/servicos/" class="btn-primary"> Ver serviços </a>
        <a
          href={whatsappUrl(settings.whatsapp, 'Olá! Gostaria de conversar sobre seus serviços.')}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-secondary"
        >
          Falar no WhatsApp
        </a>
      </div>
    </div>

    <div class="order-1 flex justify-center lg:order-2">
      <div
        class="relative flex h-72 w-72 items-center justify-center overflow-hidden rounded-2xl bg-primary shadow-xl sm:h-80 sm:w-80 md:h-96 md:w-96"
        role="img"
        aria-label="Foto profissional de Karen Bortolini — em breve"
      >
        <img
          src="/images/karen-placeholder.svg"
          alt=""
          class="absolute inset-0 h-full w-full object-cover opacity-30"
          width="400"
          height="400"
        />
        <div class="relative z-10 text-center">
          <span class="font-display text-6xl font-bold text-white/90 md:text-7xl">KB</span>
          <p class="mt-2 text-sm text-white/70">Foto em breve</p>
        </div>
      </div>
    </div>
  </div>
</section>
