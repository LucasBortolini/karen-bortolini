---
import { getSiteSettings } from '../lib/site';

const settings = await getSiteSettings();
const year = new Date().getFullYear();

---

<footer class="section-dark border-t border-white/10">
  <div class="site-container py-12 md:py-14">
    <div class="flex flex-col gap-10 lg:flex-row lg:items-end lg:justify-between">
      <div class="space-y-4">
        <a href="/" class="inline-block">
          <img
            src="/logo.png"
            alt={settings.siteName}
            width="477"
            height="633"
            class="h-14 w-auto"
            decoding="async"
          />
        </a>
        <p class="max-w-md text-sm leading-relaxed text-white/60">{settings.footerTagline}</p>

        <nav
          class="flex flex-nowrap items-center gap-2 overflow-x-auto text-sm whitespace-nowrap"
          aria-label="Contato"
        >
          <a
            href={`https://wa.me/${settings.whatsapp}`}
            class="footer-contact-link shrink-0"
            target="_blank"
            rel="noopener noreferrer"
          >
            WhatsApp
          </a>
          <span class="text-white/25" aria-hidden="true">·</span>
          <a href={`mailto:${settings.email}`} class="footer-contact-link shrink-0">
            E-mail
          </a>
          <span class="text-white/25" aria-hidden="true">·</span>
          <a
            href={settings.linkedin}
            class="footer-contact-link shrink-0"
            target="_blank"
            rel="noopener noreferrer"
          >
            LinkedIn
          </a>
        </nav>
      </div>

      <a href="/contato/" class="btn-primary shrink-0 self-start lg:self-auto">Contato</a>
    </div>

    <p class="mt-10 text-xs text-white/40 lg:mt-12">
      &copy; {year} {settings.siteName}
    </p>
  </div>
</footer>
