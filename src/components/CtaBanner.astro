---
import { getSiteSettings, whatsappUrl } from '../lib/site';

const settings = await getSiteSettings();
---

<section class="section-dark py-16 md:py-20">
  <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
    <h2 class="font-display text-3xl font-bold text-white md:text-4xl">
      Vamos conversar sobre seu projeto?
    </h2>
    <p class="mt-4 text-lg text-white/80">
      Comunicação estratégica, conteúdo multimídia ou educação digital — entre em contato.
    </p>
    <div class="mt-8 flex flex-col justify-center gap-4 sm:flex-row">
      <a href="/contato/" class="btn-primary"> Página de contato </a>
      <a
        href={whatsappUrl(settings.whatsapp)}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-outline-light"
      >
        WhatsApp
      </a>
    </div>
  </div>
</section>
