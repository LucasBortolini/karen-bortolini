---
const pillars = [
  {
    title: 'Comunicação estratégica',
    description:
      'Consultoria, assessoria de imprensa e planejamento integrado para posicionamento e resultados.',
    icon: 'strategy',
  },
  {
    title: 'Conteúdo multimídia',
    description:
      'Produção audiovisual, storytelling e conteúdos para sites, redes e materiais institucionais.',
    icon: 'media',
  },
  {
    title: 'Educação digital',
    description:
      'Design instrucional, videoaulas, tutoria e metodologias ativas com inteligência artificial.',
    icon: 'education',
  },
];
---

<section class="bg-white py-12 md:py-16">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <header class="mb-10 text-center md:mb-14">
      <p class="mb-2 text-sm font-semibold uppercase tracking-wider text-gold">Áreas de atuação</p>
      <h2 class="font-display text-3xl font-bold text-primary md:text-4xl">
        Comunicação, educação e tecnologia
      </h2>
    </header>

    <div class="grid gap-6 md:grid-cols-3">
      {
        pillars.map((pillar) => (
          <article class="card fade-in text-center md:text-left">
            <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-lg bg-gold/10 text-gold">
              {pillar.icon === 'strategy' && (
                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                </svg>
              )}
              {pillar.icon === 'media' && (
                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
                </svg>
              )}
              {pillar.icon === 'education' && (
                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                </svg>
              )}
            </div>
            <h3 class="font-display text-xl font-semibold text-primary">{pillar.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-secondary">{pillar.description}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
