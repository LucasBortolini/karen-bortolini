---
import { academicGroupLabels, academicTypeLabels, youtubeThumbnail } from '../lib/utils';

interface Item {
  title: string;
  url: string;
  type: string;
  year?: number;
}

interface Props {
  items: Item[];
  groupByType?: boolean;
}

const { items, groupByType = false } = Astro.props;

const typeOrder = ['article', 'chapter', 'thesis', 'class'];

function groupItems(all: Item[]) {
  const groups: Record<string, Item[]> = {};
  for (const item of all) {
    if (!groups[item.type]) groups[item.type] = [];
    groups[item.type].push(item);
  }
  return typeOrder
    .filter((t) => groups[t]?.length)
    .map((t) => ({ type: t, label: academicGroupLabels[t], items: groups[t] }));
}
---

{
  groupByType ? (
    groupItems(items).map((group) => (
      <div class="mb-10">
        <h3 class="mb-4 font-display text-xl font-semibold text-primary">{group.label}</h3>
        {group.type === 'class' ? (
          <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {group.items.map((item) => {
              const thumb = youtubeThumbnail(item.url);
              return (
                <a
                  href={item.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="card group block overflow-hidden p-0 hover:ring-gold/30"
                >
                  <div class="relative aspect-video overflow-hidden bg-primary/10">
                    {thumb ? (
                      <img
                        src={thumb}
                        alt=""
                        class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                        loading="lazy"
                        width="480"
                        height="270"
                      />
                    ) : (
                      <div class="flex h-full items-center justify-center bg-primary/5">
                        <span class="font-display text-lg text-primary/40">Aula</span>
                      </div>
                    )}
                    <span class="absolute left-3 top-3 rounded-full bg-gold px-2 py-0.5 text-xs font-semibold text-white">
                      Aula
                    </span>
                  </div>
                  <div class="p-4">
                    <h4 class="font-display text-base font-semibold text-primary group-hover:text-gold">
                      {item.title}
                    </h4>
                    <p class="mt-2 text-xs text-secondary/70">Assistir no YouTube →</p>
                  </div>
                </a>
              );
            })}
          </div>
        ) : (
          <ul class="space-y-3">
            {group.items.map((item) => (
              <li>
                <a
                  href={item.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="card flex items-start justify-between gap-4 hover:ring-gold/30"
                >
                  <span class="font-medium text-primary hover:text-gold">{item.title}</span>
                  <span class="shrink-0 text-gold" aria-hidden="true">
                    →
                  </span>
                </a>
              </li>
            ))}
          </ul>
        )}
      </div>
    ))
  ) : (
    <ul class="space-y-3">
      {items.map((item) => (
        <li>
          <a
            href={item.url}
            target="_blank"
            rel="noopener noreferrer"
            class="card flex items-start justify-between gap-4 hover:ring-gold/30"
          >
            <div>
              <span class="text-xs font-semibold uppercase text-gold">
                {academicTypeLabels[item.type]}
              </span>
              <p class="mt-1 font-medium text-primary">{item.title}</p>
            </div>
            <span class="shrink-0 text-gold" aria-hidden="true">→</span>
          </a>
        </li>
      ))}
    </ul>
  )
}
