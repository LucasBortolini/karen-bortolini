---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import Section from '../components/Section.astro';
import Timeline from '../components/Timeline.astro';
import { pageBanners } from '../lib/banners';
import { getSiteSettings } from '../lib/site';
import { getCollection } from 'astro:content';

const settings = await getSiteSettings();

const education = await getCollection('education');
const degrees = education
  .filter((e) => e.data.kind === 'degree')
  .sort((a, b) => a.data.order - b.data.order)
  .map((e) => e.data);

const courses = education
  .filter((e) => e.data.kind === 'course')
  .sort((a, b) => a.data.order - b.data.order)
  .map((e) => e.data);
---

<BaseLayout
  title="Sobre | Karen Bortolini"
  description="Pós-doutora em Comunicação. Trajetória em comunicação estratégica, multimídia e educação digital."
  transparentHeader
  bannerImage={pageBanners.sobre}
>
  <PageHero
    image={pageBanners.sobre}
    label="Sobre"
    title="Karen Bortolini"
    description={settings.tagline}
    imagePosition="center 35%"
  />

  <Section variant="white" class="!pt-8 md:!pt-10">
    <div class="mx-auto max-w-3xl">
      <div class="mt-8 space-y-4 text-base leading-relaxed text-secondary">
        {settings.aboutBio.map((paragraph) => <p>{paragraph}</p>)}
      </div>

      <a
        href={settings.lattes}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-6 inline-flex items-center gap-2 font-semibold text-gold hover:text-primary"
      >
        Currículo Lattes
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </Section>

  <Section title="Formação e atualização" variant="light">
    <Timeline degrees={degrees} courses={courses} />
  </Section>

</BaseLayout>
