---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import Section from '../components/Section.astro';
import { pageBanners } from '../lib/banners';
import { getSiteSettings, whatsappUrl } from '../lib/site';

const settings = await getSiteSettings();
const waLink = whatsappUrl(
  settings.whatsapp,
  'Olá! Gostaria de conversar sobre seus serviços.',
);
---

<BaseLayout
  title="Contato | Karen Bortolini"
  description="Entre em contato com Karen Bortolini por WhatsApp, e-mail, Instagram ou LinkedIn."
  transparentHeader
  bannerImage={pageBanners.contato}
>
  <PageHero
    image={pageBanners.contato}
    label="Contato"
    title="Vamos conversar"
    description="Tire dúvidas sobre serviços, projetos acadêmicos ou parcerias institucionais. Prefira WhatsApp ou e-mail — resposta o mais breve possível."
    imagePosition="center 40%"
  />

  <Section variant="light" title="Canais de contato" class="!pt-8 md:!pt-10">
    <ul class="mx-auto grid max-w-3xl gap-4 sm:grid-cols-2">
      <li class="card">
        <p class="text-sm font-semibold text-gold">WhatsApp</p>
        <a
          href={waLink}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-1 block text-lg font-medium text-primary hover:text-cta"
        >
          {settings.whatsappDisplay}
        </a>
      </li>
      <li class="card">
        <p class="text-sm font-semibold text-gold">E-mail</p>
        <a
          href={`mailto:${settings.email}`}
          class="mt-1 block text-lg font-medium text-primary hover:text-gold break-all"
        >
          {settings.email}
        </a>
      </li>
      <li class="card">
        <p class="text-sm font-semibold text-gold">Instagram</p>
        <a
          href={settings.instagramUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-1 block font-medium text-primary hover:text-gold"
        >
          {settings.instagram}
        </a>
      </li>
      <li class="card">
        <p class="text-sm font-semibold text-gold">LinkedIn</p>
        <a
          href={settings.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-1 block font-medium text-primary hover:text-gold"
        >
          linkedin.com/in/karen-bortolini
        </a>
      </li>
      <li class="card sm:col-span-2">
        <p class="text-sm font-semibold text-gold">Currículo Lattes</p>
        <a
          href={settings.lattes}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-1 block font-medium text-primary hover:text-gold"
        >
          Acessar Lattes →
        </a>
      </li>
    </ul>
  </Section>
</BaseLayout>
