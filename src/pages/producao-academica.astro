---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import Section from '../components/Section.astro';
import AcademicList from '../components/AcademicList.astro';
import { pageBanners } from '../lib/banners';
import { getCollection } from 'astro:content';

const academic = (await getCollection('academic')).sort(
  (a, b) => a.data.order - b.data.order,
);

const items = academic.map((a) => ({
  title: a.data.title,
  url: a.data.url,
  type: a.data.type,
  year: a.data.year,
}));
---

<BaseLayout
  title="Produção acadêmica | Karen Bortolini"
  description="Artigos científicos, capítulos de livros, tese de doutorado e videoaulas de Karen Bortolini."
  transparentHeader
  bannerImage={pageBanners.academica}
>
  <PageHero
    image={pageBanners.academica}
    label="Produção acadêmica"
    title="Pesquisa e materiais didáticos"
    description="Publicações, tese e trechos de aulas em instituições de ensino superior."
    imagePosition="center 30%"
  />

  <Section variant="light" class="!pt-8 md:!pt-10">
    <AcademicList items={items} groupByType={true} />
  </Section>

</BaseLayout>
