---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import AcademicList from '../components/AcademicList.astro';
import CtaBanner from '../components/CtaBanner.astro';
import { getCollection } from 'astro:content';

const academic = (await getCollection('academic')).sort(
  (a, b) => a.data.order - b.data.order,
);

const items = academic.map((a) => ({
  title: a.data.title,
  url: a.data.url,
  type: a.data.type,
  year: a.data.year,
}));
---

<BaseLayout
  title="Produção acadêmica | Karen Bortolini"
  description="Artigos científicos, capítulos de livros, tese de doutorado e videoaulas da Profª. Drª. Karen Bortolini."
>
  <Section variant="white" class="pt-8">
    <p class="mb-2 text-sm font-semibold uppercase tracking-wider text-accent">
      Produção acadêmica
    </p>
    <h1 class="font-display text-4xl font-bold text-primary md:text-5xl">
      Pesquisa e material didático
    </h1>
    <p class="mt-4 max-w-2xl text-lg text-secondary">
      Publicações, tese e trechos de aulas em instituições de ensino superior.
    </p>
  </Section>

  <Section variant="light">
    <AcademicList items={items} groupByType={true} />
  </Section>

  <CtaBanner />
</BaseLayout>
