---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import Section from '../components/Section.astro';
import PortfolioGrid from '../components/PortfolioGrid';
import { getCollection } from 'astro:content';
import { youtubeThumbnail } from '../lib/utils';

const portfolio = (await getCollection('portfolio')).sort(
  (a, b) => a.data.order - b.data.order,
);

const items = portfolio.map((p) => ({
  id: p.id,
  title: p.data.title,
  url: p.data.url,
  type: p.data.type,
  group: p.data.group,
  thumb: youtubeThumbnail(p.data.url),
}));
---

<BaseLayout
  title="Portfólio | Karen Bortolini"
  description="Produções audiovisuais, editoriais e institucionais — telejornal, documentários, boletins e revistas."
  transparentHeader
>
  <PageHero
    image="/images/banners/portifolio.jpg"
    label="Portfólio"
    title="Trabalhos realizados"
    description="Seleção de projetos em vídeo, editorial e materiais institucionais."
    imagePosition="center 45%"
  />

  <Section variant="light" class="!pt-8 md:!pt-10">
    <PortfolioGrid client:load items={items} />
  </Section>

</BaseLayout>
