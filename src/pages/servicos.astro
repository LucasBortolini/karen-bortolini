---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import Section from '../components/Section.astro';
import ServiceAccordion from '../components/ServiceAccordion.astro';
import { pageBanners } from '../lib/banners';
import { buildServiceGroups } from '../lib/services';
import { getCollection } from 'astro:content';

const serviceGroups = buildServiceGroups(await getCollection('services'));
---

<BaseLayout
  title="Serviços | Karen Bortolini"
  description="Comunicação estratégica, conteúdo multimídia, assessoria de imprensa, design instrucional e EaD."
  transparentHeader
  bannerImage={pageBanners.servicos}
>
  <PageHero
    image={pageBanners.servicos}
    label="Serviços"
    title="Como posso ajudar"
    description="Soluções em comunicação estratégica, produção multimídia e educação digital para empresas, instituições e projetos acadêmicos. Toque em um card para ver os detalhes."
    imagePosition="center 40%"
  />

  <Section variant="light" class="!pt-8 md:!pt-10">
    <ServiceAccordion groups={serviceGroups} columnId="servicos" />
  </Section>
</BaseLayout>
