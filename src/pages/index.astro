---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import PageHero from '../components/PageHero.astro';
import Pillars from '../components/Pillars.astro';
import Section from '../components/Section.astro';
import ServiceAccordion from '../components/ServiceAccordion.astro';
import PortfolioCard from '../components/PortfolioCard.astro';
import ClientLogos from '../components/ClientLogos.astro';
import { pageBanners } from '../lib/banners';
import { getSiteSettings } from '../lib/site';
import { buildServiceGroups } from '../lib/services';
import { getCollection } from 'astro:content';

const settings = await getSiteSettings();

const serviceGroups = buildServiceGroups(await getCollection('services'), {
  limitPerCategory: 3,
});

const portfolioFeatured = (await getCollection('portfolio'))
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 4);
---

<BaseLayout
  title={settings.meta.homeTitle}
  description={settings.meta.homeDescription}
  transparentHeader
  bannerImage={pageBanners.home}
  socialImage={pageBanners.home}
>
  <PageHero
    image={pageBanners.home}
    label={settings.siteName}
    title={settings.heroTitle}
    description={settings.heroSubtitle}
    imagePosition="center center"
  />

  <Hero />
  <Pillars />

  <Section title="Serviços" subtitle="O que faço" variant="light">
    <ServiceAccordion groups={serviceGroups} columnId="home" />
    <div class="mt-10 text-center">
      <a href="/servicos/" class="btn-secondary"> Ver todos os serviços </a>
    </div>
  </Section>

  <Section title="Portfólio em destaque" subtitle="Trabalhos recentes" variant="white">
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {portfolioFeatured.map((p) => (
        <PortfolioCard
          title={p.data.title}
          url={p.data.url}
          type={p.data.type}
          group={p.data.group}
        />
      ))}
    </div>
    <div class="mt-10 text-center">
      <a href="/portfolio/" class="btn-secondary"> Ver portfólio completo </a>
    </div>
  </Section>

  <ClientLogos />
</BaseLayout>
